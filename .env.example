# ============================================
# 校园求职规划多Agent系统 — 环境变量配置模板
# 使用方法：
# 1. 复制此文件，改名为 .env
# 2. 将下面的占位符替换为你的真实 API Key
# 3. 保存后即可启动项目
# ============================================

# ====== 通义千问 DashScope API Key ======
# 获取地址：https://dashscope.console.aliyun.com/apiKey
# 用途：LLM 文本生成、Embedding 向量化
DASHSCOPE_API_KEY=sk-你的通义千问APIKey在这里

# ====== Tavily 搜索 API Key ======
# 获取地址：https://tavily.com/
# 用途：联网搜索岗位信息
TAVILY_API_KEY=tvly-你的TavilyAPIKey在这里

# ====== 可选：其他配置 ======
# 如需使用其他模型（如 DeepSeek、OpenAI），可以在这里添加
# DEEPSEEK_API_KEY=sk-xxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxx